function run_cmd_on_many() {
  # Run a specified command on multiple remote servers via SSH.
  # Usage: run_cmd_on_many "<command>" [user@server1 user@server2 ...]
  # Example: run_cmd_on_many "uptime; df -h /" user@server1 user@server2 user@server3
  COMMAND_TO_RUN="$1"
  SERVER_LIST=()
  # all other arguments are servers
  for arg in "$@"; do
      if [ "$arg" != "$COMMAND_TO_RUN" ]; then
          SERVER_LIST+=("$arg.wv.mentorg.com")
      fi
  done
  if [ "${#SERVER_LIST[@]}" -eq 0 ]; then
      echo "No servers provided. Please provide at least one server."
      return 1
  fi
  echo "Starting remote command execution on multiple servers with enhanced debugging..."
  echo "-----------------------------------------------------------------"

  # Loop through each server in our list
  for SERVER_ENTRY in "${SERVER_LIST[@]}"; do

      # Execute the command remotely using SSH with verbose output
      # -v: Verbose SSH output (use -vv or -vvv for more detail if needed)
      # -o BatchMode=yes: Prevents SSH from asking for passwords if key auth fails.
      # -o ConnectTimeout=10: Increased timeout (in seconds) for connection attempts.
      #                      Adjust as needed for your network.
      # -T: Disables pseudo-terminal allocation. Good for non-interactive commands.
      # 2>&1: Redirects stderr to stdout, so all SSH and remote command output goes to the log.
      ssh -o BatchMode=yes -o ConnectTimeout=10 -T "$SERVER_ENTRY" "$COMMAND_TO_RUN"

      # Check the exit status of the SSH command (which now reflects the remote command's exit status)
      SSH_EXIT_STATUS=$?

      if [ "$SSH_EXIT_STATUS" -eq 0 ]; then
          echo "✅ Command executed successfully on $SERVER_ENTRY."
      else
          echo "❌ ERROR: Command failed or SSH connection issue on $SERVER_ENTRY. Exit code: $SSH_EXIT_STATUS" >&2
      fi
      echo "-----------------------------------------------------------------"
  done

  printf "\nRemote command execution completed on all servers.\n"
}

