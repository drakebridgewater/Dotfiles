function log() {
  local level="$1"
  local message="$2"
  local timestamp
  timestamp=$(date +"%Y-%m-%d %H:%M:%S")
  # return if level is DEBUG and DEBUG is not set or is 0
  if [ "$level" = "DEBUG" ] && [ -z "$DEBUG" ]; then
    return
  fi
  echo "[$timestamp] [$level] $message"
}

function getBuildCmd() {
  # Given the argument logpath and offending file name it returns ( cd ic/lv/aok; cglu; gmake -Tclang -Tnocuda -Twarn -C lithas/calibrewb/ ../main_src/cwb/mdf_plot.o )
  local offending_file="$1"
  local logpath=$(realpath "$2")

  local vco=$(getVCOFromLogFilePath "$logpath")
  log "DEBUG" "VCO=$vco"
  if [ -z "$vco" ]; then
    log "ERROR" "Could not determine VCO from log file path '$logpath'."
    return 1
  fi

  local vco_flags
  vco_flags=$(getBuildFlagsFromVCO "$vco")
  log "DEBUG" "VCO Flags=$vco_flags"
  if [ -z "$vco_flags" ]; then
    log "ERROR" "Could not determine build flags from VCO '$vco'."
    return 1
  fi

  local log_line
  log_line=$(getOGBuildCmd "$offending_file" "$logpath")
  log "DEBUG" "Log Line=$log_line"
  if [ -z "$log_line" ]; then
    log "ERROR" "Could not find build command for offending file '$offending_file' in log '$logpath'."
    return 1
  fi

  local build_target
  build_target=$(getBuildTarget "$log_line")
  log "DEBUG" "Build Target=$build_target"
  if [ -z "$build_target" ]; then
    log "ERROR" "Could not determine build target from log line."
    return 1
  fi

  local target_build_line_number
  target_build_line_number=$(getLogLineNumber "$log_line")
  log "DEBUG" "Build Line Number=$target_build_line_number"

  local entering_directory
  entering_directory=$(getEnteringDirectory "$logpath" "$target_build_line_number")
  log "DEBUG" "Entering Directory Line=$entering_directory"

  local build_directory
  build_directory=$(getBuildDirectory "$entering_directory" "$vco")
  log "DEBUG" "Build Directory=$build_directory"

  local src_dir
  src_dir=$(getSrcDir "$entering_directory" "$vco")
  log "DEBUG" "Source Directory=$src_dir"

  # Construct the build command
  local build_cmd="( cd "$src_dir"; cglu; gmake $vco_flags -C $build_directory $build_target )"
  echo "$build_cmd"
}

function getFailingBuildCmd() {
  # Given the argument logpath and offending file name it returns ( cd ic/lv/aok; cglu; gmake -Tclang -Tnocuda -Twarn -C lithas/calibrewb/ ../main_src/cwb/mdf_plot.o )
  local logpath="$1"
  local DEBUG=${DEBUG:-0}

  if [ -z "$logpath" ]; then
    echo "Usage: getBuildCmd <logpath>"
    return 1
  fi
  log "DEBUG" "logpath=$logpath"

  first_errors=$(getFirstErrors "$logpath")
  log "DEBUG" "First Errors=$first_errors"
  if [ -z "$first_errors" ]; then
    log "ERROR" "No errors found in log file '$logpath'."
    return 1
  fi
  local error_line_number
  error_line_number=$(echo "$first_errors" | cut -d: -f1)
  log "INFO" "Error Line Number=$error_line_number"

  offending_file=$(getOffendingFileFromErrorLine "$first_errors")
  if [ -z "$offending_file" ]; then
    log "ERROR" "Could not determine offending file from error line."
    log "INFO" "Trying something else"
    offending_file=$(getPreviousBuildFile "$logpath" "$error_line_number")
    if [ -z "$offending_file" ]; then
      log "ERROR" "Could not determine offending file from error line."
      return 1
    fi
  fi
  case "$offending_file" in
  *.h | *.c | *.cpp | *.C)
    offending_file="${offending_file%.*}"
    ;;
  esac
  log "DEBUG" "Offending File=$offending_file"
  local build_cmd
  build_cmd=$(getBuildCmd "$offending_file" "$logpath")
  echo "$build_cmd"
}

function check_git_consistency() {
  local search_dir="${1:-.}"
  local pattern="${2:-src}"
  local max_depth="${3:-2}"
  local use_tags="${4:-0}"
  local tag_prefix="${5:-cb_}"

  help_msg="Usage: check_git_consistency [search_dir] [pattern] [max_depth] [use_tags] [tag_prefix]
    - search_dir: Directory to start searching (default: current directory)
    - pattern: Pattern to match directory names (default: 'src')
    - max_depth: Maximum depth for the search (default: 2)
    - use_tags: If set to 1, checks git tags instead of commit hashes (default: 0)
    - tag_prefix: Prefix for tags to consider when use_tags is 1 (default: 'cb_')"
  if [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    echo "$help_msg"
    return 0
  fi

  echo "Checking Git repository consistency in $search_dir"
  search_dir=$(realpath "$search_dir")

  # Find all matching directories and get their tags
  local result
  if [ "$use_tags" -eq 1 ]; then
    local find_bash_cmd
    find_bash_cmd=' PATH=/usr/bin:/bin:$PATH ; cd "{}" 2>/dev/null && tag_prefix="'"$tag_prefix"'" ; tags=$(git tag --points-at HEAD 2>/dev/null | grep "^$tag_prefix" | head -1) ; if [ -n "$tags" ]; then echo "$tags ({})" ; else echo "NO_MATCHING_TAG ({})" ; fi '
    result=$( find "$search_dir" -maxdepth "$max_depth" -type d -name "*$pattern*" -exec bash -c "$find_bash_cmd" \; )
  else
    local find_bash_cmd
    find_bash_cmd=' PATH=/usr/bin:/bin:$PATH ; cd "{}" 2>/dev/null && git rev-parse HEAD && echo " ({})" '
    result=$( find "$search_dir" -maxdepth "$max_depth" -type d -name "*$pattern*" -exec bash -c "$find_bash_cmd" \; )
  fi

  # Count unique SHAs (excluding repo paths)
  local unique_result_count
  unique_result_count=$(echo "$result" | cut -d' ' -f1 | sort -u | wc -l)

  # Get list of SHAs
  if [ "$unique_result_count" -gt 1 ]; then
    echo "ERROR: Found $unique_result_count different results!"
    echo "$result" | awk '{
            sha = $1;
            repo = substr($0, length(sha) + 2);
            # Remove newlines
            gsub(/\n/, "", sha);
            gsub(/\n/, "", repo);
            if (prev_sha != sha) {
                printf "  %s: %s\n", sha, repo;
                prev_sha = sha;
            } else {
                printf "    - %s\n", repo;
            }
        }'
    return 1
  elif [ "$unique_result_count" -eq 0 ]; then
    echo "No git repositories found."
    return 1
  else
    local sha
    sha=$(echo "$result" | head -1 | cut -d' ' -f1)
    echo "Success: All repositories have the same commit hash: $sha"
    return 0
  fi
}

function check_git_tag_consistency(){
  check_git_consistency "$1" "$2" "$3" 1
}

