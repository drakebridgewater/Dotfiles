function get_warnings_on_all_build_logs() {
  local search_dir="${1:-.}"
  local pattern="\.BUILD\.a"
  local max_depth="${3:-3}"
  local vco

  local warning_cmd
  local warning_script="/home/drabri2r/Projects/calibre-development-tools/bin/getWarnings"
  local resolved_search_dir
  resolved_search_dir=$(realpath "$search_dir")

  echo "Searching for warnings in build logs under $resolved_search_dir"

  find "$resolved_search_dir" -maxdepth "$max_depth" -type f -name "*$pattern*" | while read logfile; do
      vco=$(echo "$logfile" | sed -E 's/.*\.BUILD\.(.*)/\1/')
      log_file_directory=$(dirname "$logfile")
      output_file="$log_file_directory/${vco}.warnings.json"
      stats_output_file="$log_file_directory/${vco}.cwarn_summary.json"
      local iwa=$(realpath "${log_file_directory}/../")
      warning_cmd="$warning_script --logfile $logfile --iwa $iwa --build-vco $vco --output $output_file --stats-output $stats_output_file"
      echo "----- Warnings in $logfile -----"
      echo "Running command: $warning_cmd"
      eval "$warning_cmd"
      echo "Warnings saved to $output_file"
      echo "--------------------------------"
  done
}

