#!/usr/bin/env bash
#
# rescue-my-commits.sh
#
# Run this from your workarea when your commits won't push because the
# remote branch moved out from under you (e.g. it was rebased).
#
# What it does:
#   1. Figures out who you are and what branch you're on
#   2. Finds YOUR commits (not other people's)
#   3. Fetches the latest remote branch
#   4. Creates a new branch from the latest remote
#   5. Replays your commits on top of it
#   6. Tells you what to do next (push)
#
# Usage:  cd /your/workarea && ./rescue-my-commits.sh
#         ./rescue-my-commits.sh --dry-run               # preview only
#         ./rescue-my-commits.sh --verbose               # extra debug output
#         ./rescue-my-commits.sh --user "Jane Doe"       # rescue another user's commits
#         ./rescue-my-commits.sh --user "jane@corp.com"  # match by email
#
set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; BOLD='\033[1m'; NC='\033[0m'

step()  { printf "\n${BOLD}${BLUE}── Step %s: %s${NC}\n" "$1" "$2"; }
info()  { printf "   ${BLUE}ℹ${NC}  %s\n" "$*"; }
ok()    { printf "   ${GREEN}✔${NC}  %s\n" "$*"; }
warn()  { printf "   ${YELLOW}⚠${NC}  %s\n" "$*"; }
err()   { printf "   ${RED}✘${NC}  %s\n" "$*" >&2; }
die()   { err "$@"; exit 1; }
debug() { $VERBOSE && printf "   ${YELLOW}DBG${NC} %s\n" "$*" || true; }

confirm() {
    local prompt="${1:-Proceed?}"
    if $DRY_RUN; then return 0; fi
    printf "\n   ${BOLD}%s${NC} [Y/n] " "$prompt"
    read -r answer </dev/tty
    case "${answer:-y}" in
        [Yy]|[Yy]es) return 0 ;;
        *) warn "Aborted by user."; exit 1 ;;
    esac
}

DRY_RUN=false
VERBOSE=false
TARGET_USER=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --dry-run)  DRY_RUN=true; shift ;;
        --verbose)  VERBOSE=true; shift ;;
        --user)     [[ -n "${2:-}" ]] || die "--user requires a name or email argument"
                    TARGET_USER="$2"; shift 2 ;;
        -h|--help)  echo "Usage: $(basename "$0") [--dry-run] [--verbose] [--user <name|email>]"; exit 0 ;;
        *)          die "Unknown option: $1" ;;
    esac
done

$VERBOSE && info "Verbose mode enabled" || true
$DRY_RUN && info "Dry-run mode — no changes will be made" || true

# ─────────────────────────────────────────────────────────────────────────────
step 1 "Figure out where we are"
# ─────────────────────────────────────────────────────────────────────────────

# Make sure we're in a git repo
git rev-parse --git-dir >/dev/null 2>&1 || die "This is not a git repository."
debug "Git dir: $(git rev-parse --git-dir)"
debug "Working tree: $(git rev-parse --show-toplevel)"

# What branch am I on?
CURRENT_BRANCH="$(git branch --show-current)"
[[ -n "$CURRENT_BRANCH" ]] || die "You're in detached HEAD state. Check out a branch first."
ok "You are on branch: $CURRENT_BRANCH"
debug "HEAD is at: $(git rev-parse HEAD)"

# What remote does it track?
REMOTE="$(git config "branch.${CURRENT_BRANCH}.remote" 2>/dev/null || true)"
REMOTE_BRANCH="$(git config "branch.${CURRENT_BRANCH}.merge" 2>/dev/null || true)"
REMOTE_BRANCH="${REMOTE_BRANCH#refs/heads/}"  # strip refs/heads/ prefix

if [[ -z "$REMOTE" || -z "$REMOTE_BRANCH" ]]; then
    # No tracking info — guess origin/<current-branch>
    REMOTE="origin"
    REMOTE_BRANCH="$CURRENT_BRANCH"
    warn "No tracking branch set. Assuming ${REMOTE}/${REMOTE_BRANCH}"
else
    ok "Tracking: ${REMOTE}/${REMOTE_BRANCH}"
fi
debug "Remote: $REMOTE"
debug "Remote branch: $REMOTE_BRANCH"

# Who are we rescuing commits for?
if [[ -n "$TARGET_USER" ]]; then
    # User specified on command line — use as both name and email search
    MY_NAME="$TARGET_USER"
    MY_EMAIL="$TARGET_USER"
    AUTHOR="$TARGET_USER"
    ok "Rescuing commits for: $TARGET_USER"
else
    MY_NAME="$(git config user.name 2>/dev/null || true)"
    MY_EMAIL="$(git config user.email 2>/dev/null || true)"
    AUTHOR="${MY_NAME:-$MY_EMAIL}"
    [[ -n "$AUTHOR" ]] || die "Cannot determine your git identity. Run: git config user.name 'Your Name'"
    ok "Your git identity: $AUTHOR ($MY_EMAIL)"
fi

# ─────────────────────────────────────────────────────────────────────────────
step 2 "Fetch the latest remote branch"
# ─────────────────────────────────────────────────────────────────────────────

info "Running: git fetch ${REMOTE} ${REMOTE_BRANCH}"
if $VERBOSE; then
    git fetch "$REMOTE" "$REMOTE_BRANCH" || die "Fetch failed. Check your network/remote."
else
    git fetch "$REMOTE" "$REMOTE_BRANCH" --quiet || die "Fetch failed. Check your network/remote."
fi
ok "Fetched latest ${REMOTE}/${REMOTE_BRANCH}"
debug "Remote HEAD: $(git rev-parse "${REMOTE}/${REMOTE_BRANCH}")"

# ─────────────────────────────────────────────────────────────────────────────
step 3 "Find YOUR commits"
# ─────────────────────────────────────────────────────────────────────────────
#
# We find the point where your branch and the remote last shared history
# (the merge-base), then list YOUR commits since that point.
# Commits by other people are skipped — they're already on the remote.
#

REMOTE_REF="${REMOTE}/${REMOTE_BRANCH}"
MERGE_BASE="$(git merge-base HEAD "$REMOTE_REF" 2>/dev/null || true)"

if [[ -z "$MERGE_BASE" ]]; then
    die "No common history between your branch and ${REMOTE_REF}. Are you on the right branch?"
fi

info "Common ancestor: $(git log --oneline -1 "$MERGE_BASE")"
debug "Merge base SHA: $MERGE_BASE"
debug "Commits on local since merge-base: $(git rev-list --count "${MERGE_BASE}..HEAD")"
debug "Commits on remote since merge-base: $(git rev-list --count "${MERGE_BASE}..${REMOTE_REF}")"
debug "Searching for commits by author: name=\"$MY_NAME\" email=\"$MY_EMAIL\""

# Get your commits (by author name OR email), oldest first, no merges
mapfile -t MY_SHAS < <(
    git log --format="%H" --no-merges --reverse \
        --author="$MY_NAME" --author="$MY_EMAIL" \
        "${MERGE_BASE}..HEAD"
)
debug "Found ${#MY_SHAS[@]} candidate commit(s) before dedup"

# Deduplicate: skip any whose patch-id already exists on the remote
SHAS=()
for sha in "${MY_SHAS[@]}"; do
    SRC_PID="$(git show "$sha" 2>/dev/null | git patch-id --stable 2>/dev/null | awk '{print $1}')"
    [[ -z "$SRC_PID" ]] && continue

    FOUND=false
    while IFS= read -r tsha; do
        TGT_PID="$(git show "$tsha" 2>/dev/null | git patch-id --stable 2>/dev/null | awk '{print $1}')"
        [[ "$SRC_PID" == "$TGT_PID" ]] && { FOUND=true; break; }
    done < <(git log --format="%H" --no-merges "${MERGE_BASE}..${REMOTE_REF}" 2>/dev/null)

    if $FOUND; then
        warn "Already on remote, skipping: $(git log --oneline -1 "$sha")"
        debug "Duplicate patch-id: $SRC_PID"
    else
        SHAS+=("$sha")
        debug "Unique commit: $(git log --oneline -1 "$sha") (patch-id: $SRC_PID)"
    fi
done
debug "${#SHAS[@]} unique commit(s) to rescue after dedup"

if [[ ${#SHAS[@]} -eq 0 ]]; then
    ok "All your commits are already on ${REMOTE_REF}. Nothing to do!"
    exit 0
fi

echo ""
info "Your commits to rescue (${#SHAS[@]}):"
echo "   ───────────────────────────────────────────────────────"
for sha in "${SHAS[@]}"; do
    echo "   $(git log --oneline -1 "$sha")"
done
echo "   ───────────────────────────────────────────────────────"
if $VERBOSE; then
    echo ""
    info "Detailed commit info:"
    for sha in "${SHAS[@]}"; do
        echo ""
        git log --format="   %h %s%n      Author: %an <%ae>%n      Date:   %ai%n      Files:  " -1 "$sha"
        git diff-tree --no-commit-id --name-only -r "$sha" | sed 's/^/              /'
    done
fi

if $DRY_RUN; then
    echo ""
    info "[DRY RUN] No changes made. Remove --dry-run to proceed."
    exit 0
fi

confirm "Rescue these ${#SHAS[@]} commit(s)?"

# ─────────────────────────────────────────────────────────────────────────────
step 4 "Create a fresh branch from the latest remote"
# ─────────────────────────────────────────────────────────────────────────────
#
# We make a new branch based on the up-to-date remote. Your old branch
# is kept as a backup so nothing is lost.
#

RESCUE_BRANCH="${CURRENT_BRANCH}-rescued"
BACKUP_BRANCH="${CURRENT_BRANCH}-backup-$(date +%Y%m%d%H%M%S)"

info "Backing up current branch as: $BACKUP_BRANCH"
git branch "$BACKUP_BRANCH" HEAD
debug "Backup branch points to: $(git rev-parse HEAD)"

info "Creating rescue branch from ${REMOTE_REF}: $RESCUE_BRANCH"
git checkout -b "$RESCUE_BRANCH" "$REMOTE_REF" --quiet
ok "Now on branch: $RESCUE_BRANCH (based on latest ${REMOTE_REF})"
debug "Rescue branch starts at: $(git rev-parse HEAD)"

# ─────────────────────────────────────────────────────────────────────────────
step 5 "Replay your commits"
# ─────────────────────────────────────────────────────────────────────────────

APPLIED=0
for sha in "${SHAS[@]}"; do
    SUBJECT="$(git log --oneline -1 "$sha")"
    info "Cherry-picking: $SUBJECT"

    if git cherry-pick "$sha" 2>/dev/null; then
        ok "Applied: $SUBJECT"
        debug "New HEAD after pick: $(git rev-parse HEAD)"
        ((APPLIED++))
    else
        echo ""
        err "CONFLICT on: $SUBJECT"
        echo ""
        echo "   What to do now:"
        echo "   1. Open the conflicted files (look for <<<<<<< markers)"
        echo "   2. Edit them to keep the right version"
        echo "   3. Run:  git add <file>        (for each fixed file)"
        echo "   4. Run:  git cherry-pick --continue"
        echo ""
        echo "   Or to skip this commit:  git cherry-pick --skip"
        echo "   Or to undo everything:   git cherry-pick --abort"
        echo ""
        warn "After resolving, re-run this script to pick up the rest."
        break
    fi
done

# ─────────────────────────────────────────────────────────────────────────────
step 6 "Summary"
# ─────────────────────────────────────────────────────────────────────────────

echo ""
echo "   ═══════════════════════════════════════════════════════"
ok "Applied ${APPLIED} / ${#SHAS[@]} of your commits"
echo ""
echo "   Your old branch is backed up as: ${BACKUP_BRANCH}"
echo "   Your rescued commits are on:     ${RESCUE_BRANCH}"
echo ""
if [[ $APPLIED -eq ${#SHAS[@]} ]]; then
    echo "   ${BOLD}To push your rescued commits:${NC}"
    echo "      git push ${REMOTE} ${RESCUE_BRANCH}:${REMOTE_BRANCH}"
    echo ""
    echo "   Or push as a new branch for review:"
    echo "      git push ${REMOTE} ${RESCUE_BRANCH}"
fi
echo "   ═══════════════════════════════════════════════════════"