#fi


unalias bracketCheck 2>/dev/null
bracketCheck() {
  awk '
BEGIN {
  opens = "([{";
  closes = ")]}";
  sq = sprintf("%c", 39);
  dq = sprintf("%c", 34);
  ok = 1;
  top = 0;
}

function strip_comment(s,    i, c, out, in_single, in_double, esc) {
  out = "";
  in_single = 0;
  in_double = 0;
  esc = 0;

  for (i = 1; i <= length(s); i++) {
    c = substr(s, i, 1);

    if (in_single) {
      if (c == sq) in_single = 0;
      out = out c;
      continue;
    }

    if (in_double) {
      out = out c;
      if (c == "\\" && !esc) {
        esc = 1;
      } else {
        if (c == dq && !esc) in_double = 0;
        esc = 0;
      }
      continue;
    }

    if (c == sq) {
      in_single = 1;
      out = out c;
      continue;
    }

    if (c == dq) {
      in_double = 1;
      esc = 0;
      out = out c;
      continue;
    }

    if (c == "#" && (i == 1 || substr(s, i - 1, 1) ~ /[[:space:]]/)) break;
    out = out c;
  }

  return out;
}

function is_case_label_closer(line, pos,    before, after) {
  before = substr(line, 1, pos - 1);
  after = substr(line, pos + 1);

  if (after !~ /^[[:space:]]*$/) return 0;
  if (before !~ /[^[:space:]]/) return 0;
  if (before ~ /\(/) return 0;

  return 1;
}

{
  line = strip_comment($0);
  in_single = 0;
  in_double = 0;
  esc = 0;

  for (i = 1; i <= length(line); i++) {
    c = substr(line, i, 1);

    if (in_single) {
      if (c == sq) in_single = 0;
      continue;
    }

    if (in_double) {
      if (c == "\\" && !esc) {
        esc = 1;
      } else {
        if (c == dq && !esc) in_double = 0;
        esc = 0;
      }
      continue;
    }

    if (c == sq) {
      in_single = 1;
      continue;
    }

    if (c == dq) {
      in_double = 1;
      esc = 0;
      continue;
    }

    open_idx = index(opens, c);
    if (open_idx) {
      stack[++top] = c;
      line_no[top] = NR;
      col_no[top] = i;
      continue;
    }

    close_idx = index(closes, c);
    if (close_idx) {
      if (c == ")" && is_case_label_closer(line, i)) {
        continue;
      }

      if (top == 0) {
        printf("MISMATCH line %d col %d: unexpected %s\n", NR, i, c);
        ok = 0;
        continue;
      }

      expected = substr(closes, index(opens, stack[top]), 1);
      if (c != expected) {
        printf("MISMATCH line %d col %d: got %s, expected %s to close %s from line %d col %d\n", NR, i, c, expected, stack[top], line_no[top], col_no[top]);
        ok = 0;
        top--;
        continue;
      }

      top--;
    }
  }
}
END {
  if (top > 0) {
    for (i = top; i >= 1; i--) {
      printf("UNCLOSED %s at line %d col %d\n", stack[i], line_no[i], col_no[i]);
    }
    ok = 0;
  }

  if (ok) {
    print "OK: brackets are balanced and matching";
  }

  exit(ok ? 0 : 1);
}
' "$@"
}
