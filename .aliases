pid_by_port() {
  lsof -i -P | grep LISTEN | grep :$1
}

# Reports your path, separated into one per line for readability
alias ppath="echo $PATH | sed -e 's/:/\n/g'"

alias vi='vim'
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'

# -> Prevents accidentally clobbering files.
alias mkdir='mkdir -p'
alias encoding='file -bi'

alias h='history'
alias j='jobs -l'
alias which='type -a'
alias ..='cd ..'


alias du='du -kh'       # Makes a more readable output.
if [[ "$(uname)" == "Darwin" ]]; then
  alias df='df -kh'
else
  alias df='df -kTh'
fi

alias grep='grep --color=auto'

